# Servidor
PORT=3001
NODE_ENV=development

# Banco de Dados PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/investment_advisor

# JWT
JWT_SECRET=sua-chave-secreta-muito-segura-aqui-min-32-chars

# Frontend URL (para CORS)
FRONTEND_URL=http://localhost:5173

# APIs de Cotação (opcionais - usuários podem configurar as próprias)
BRAPI_TOKEN=seu-token-brapi
ALPHAVANTAGE_KEY=sua-api-key-alphavantage
