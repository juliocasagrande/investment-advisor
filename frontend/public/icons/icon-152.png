<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#10b981"/>
      <stop offset="100%" style="stop-color:#059669"/>
    </linearGradient>
  </defs>
  
  <!-- Background -->
  <rect width="512" height="512" rx="108" fill="url(#bg)"/>
  
  <!-- Chart bars -->
  <g fill="white">
    <!-- Bar 1 -->
    <rect x="120" y="280" width="56" height="120" rx="8"/>
    <!-- Bar 2 -->
    <rect x="200" y="200" width="56" height="200" rx="8"/>
    <!-- Bar 3 -->
    <rect x="280" y="140" width="56" height="260" rx="8"/>
    <!-- Trend line -->
    <path d="M140 260 L228 180 L308 120 L380 80" stroke="white" stroke-width="12" stroke-linecap="round" fill="none"/>
    <!-- Arrow head -->
    <polygon points="380,80 350,95 365,110" fill="white"/>
  </g>
</svg>
